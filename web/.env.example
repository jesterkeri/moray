# Privy app id — create an app at https://dashboard.privy.io
# (enable Email + Passkey login and Embedded Wallets)
NEXT_PUBLIC_PRIVY_APP_ID=

# Deployed MorayVault address on Monad testnet (from `forge script Deploy`)
NEXT_PUBLIC_MORAY_ADDRESS=

# Monad testnet RPC (default below is the public endpoint)
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz

# Optional: the vault's deployment block. Set this if the RPC caps eth_getLogs
# ranges so the Activity view doesn't scan from block 0. Defaults to 0.
NEXT_PUBLIC_MORAY_FROM_BLOCK=
